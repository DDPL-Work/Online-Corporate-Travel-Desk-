NODE_ENV=development
PORT=5000
API_VERSION=v1

FRONTEND_URL=http://localhost:5173
PRODUCTION_FRONTEND_URL=https://app.example.com

JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me

RAZORPAY_KEY_ID=replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

DEFAULT_PAYMENT_GATEWAY=phonepe
MIN_WALLET_RECHARGE_AMOUNT=100

PHONEPE_CLIENT_ID=replace_me
PHONEPE_CLIENT_SECRET=replace_me
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=SANDBOX
PHONEPE_CALLBACK_URL=https://api.example.com/api/v1/wallet/webhooks/phonepe
PHONEPE_CALLBACK_USERNAME=replace_me
PHONEPE_CALLBACK_PASSWORD=replace_me
PHONEPE_REDIRECT_URL=https://app.example.com/corporate-wallet/phonepe-status
PHONEPE_RECOVERY_CRON=*/5 * * * *
